# Lock line endings to LF for all text files, regardless of contributor OS.
# This file overrides each user's local git core.autocrlf setting, so the
# repo behaves consistently on Windows, macOS, and Linux.

# Default: detect text vs binary, store/check out text as LF.
* text=auto eol=lf

# Explicit text types (belt-and-suspenders against bad heuristics).
*.py    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Windows-native files keep CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary types (no conversion, no line-ending nonsense).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
